+    public static void startEvent4(EntityPlayerMP player) {
+        if (isEvent4Active) return;
+
+        LinkedList<Snapshot> list = playerSnapshots.get(player.username);
+        if (list == null || list.isEmpty()) {
+            // スナップショットがまだない場合は現在の状態で即時保存してターゲットにする
+            list = new LinkedList<Snapshot>();
+            list.add(new Snapshot(player));
+            playerSnapshots.put(player.username, list);
+        }
+
+        // 最古のスナップショット（約60秒前）をロールバックターゲットにする
+        rollbackTarget = list.getFirst();
+        targetPlayer = player;
+        event4StartTime = System.currentTimeMillis();
+        isEvent4Active = true;
+        soundTimer = 0;
+    }
