+package net.minecraft.src;
+
+import javax.swing.*;
+import java.awt.*;
+import java.awt.event.ActionEvent;
+import java.awt.event.ActionListener;
+import java.io.File;
+import java.util.List;
+import net.minecraft.client.Minecraft;
+
+public class SwingTexturePackWindow {
+    public static void open(final Minecraft mc, final GuiScreen parent) {
+        SwingUtilities.invokeLater(new Runnable() {
+            @Override
+            public void run() {
+                final JFrame frame = new JFrame("Select Texture Pack (Swing GUI)");
+                frame.setSize(420, 320);
+                frame.setLocationRelativeTo(null);
+                frame.setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
+                frame.setLayout(new BorderLayout());
+
+                final TexturePackList packList = mc.texturePackList;
+                List packs = packList.availableTexturePacks();
+                
+                final DefaultListModel listModel = new DefaultListModel();
+                for (int i = 0; i < packs.size(); i++) {
+                    ITexturePack pack = (ITexturePack) packs.get(i);
+                    listModel.addElement(pack.getTexturePackFileName());
+                }
+
+                final JList jList = new JList(listModel);
+                jList.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
+                
+                ITexturePack current = packList.getSelectedTexturePack();
+                if (current != null) {
+                    jList.setSelectedValue(current.getTexturePackFileName(), true);
+                }
+
+                JScrollPane scrollPane = new JScrollPane(jList);
+                frame.add(scrollPane, BorderLayout.CENTER);
+
+                JPanel btnPanel = new JPanel(new FlowLayout());
+                JButton selectBtn = new JButton("Select");
+                JButton openFolderBtn = new JButton("Open Folder");
+                
+                selectBtn.addActionListener(new ActionListener() {
+                    @Override
+                    public void actionPerformed(ActionEvent e) {
+                        int index = jList.getSelectedIndex();
+                        if (index >= 0) {
+                            List packs = packList.availableTexturePacks();
+                            ITexturePack selected = (ITexturePack) packs.get(index);
+                            
+                            packList.setTexturePack(selected);
+                            mc.renderEngine.refreshTextures();
+                            
+                            JOptionPane.showMessageDialog(frame, "Texture pack successfully changed to:\n" + selected.getTexturePackFileName());
+                        }
+                    }
+                });
+
+                openFolderBtn.addActionListener(new ActionListener() {
+                    @Override
+                    public void actionPerformed(ActionEvent e) {
+                        File folder = new File(mc.mcDataDir, "texturepacks");
+                        try {
+                            Desktop.getDesktop().open(folder);
+                        } catch (Exception ex) {
+                            ex.printStackTrace();
+                        }
+                    }
+                });
+
+                btnPanel.add(selectBtn);
+                btnPanel.add(openFolderBtn);
+                frame.add(btnPanel, BorderLayout.SOUTH);
+
+                frame.setVisible(true);
+            }
+        });
+    }
+}
