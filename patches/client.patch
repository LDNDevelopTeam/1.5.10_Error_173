+				while ((line = reader.readLine()) != null) {
+					if (line.contains("ProcessorNameString")) {
+						String[] parts = line.split("REG_SZ");
+						if (parts.length > 1) {
+							return parts[1].trim();
+						}
+					}
+				}
+			} else if (os.contains("nix") || os.contains("nux") || os.contains("aix")) {
