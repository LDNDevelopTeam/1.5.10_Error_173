+
+                soundTimer++;
+
+                if (elapsed - 4000L < 50L) {
+                    targetPlayer.addChatMessage("\u00a7c[SYSTEM] Time synchronization failed.");
+                } else if (elapsed - 4000L >= 1000L && elapsed - 4000L < 1050L) {
+                    targetPlayer.addChatMessage("\u00a7c[SYSTEM] Rolling back tick packets...");
+                } else if (elapsed - 4000L >= 2000L && elapsed - 4000L < 2050L) {
