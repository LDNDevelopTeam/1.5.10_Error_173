+package net.minecraft.src;
+
+import java.util.*;
+import net.minecraft.server.MinecraftServer;
+
+public class WorldRollbackManager {
+    public static class BlockData {
+        public int x, y, z;
+        public int blockId;
+        public int metadata;
+
+        public BlockData(int x, int y, int z, int blockId, int metadata) {
+            this.x = x;
+            this.y = y;
+            this.z = z;
+            this.blockId = blockId;
+            this.metadata = metadata;
+        }
+    }
+
+    public static class Snapshot {
+        public long timestamp;
+        public double playerX, playerY, playerZ;
+        public float playerYaw, playerPitch;
+        public ItemStack[] inventoryContents;
+        public List<BlockData> blocks;
+
+        public Snapshot(EntityPlayerMP player) {
+            this.timestamp = System.currentTimeMillis();
+            this.playerX = player.posX;
+            this.playerY = player.posY;
+            this.playerZ = player.posZ;
+            this.playerYaw = player.rotationYaw;
+            this.playerPitch = player.rotationPitch;
+
+            // インベントリのディープコピー
+            ItemStack[] inv = player.inventory.mainInventory;
+            this.inventoryContents = new ItemStack[inv.length];
+            for (int i = 0; i < inv.length; i++) {
+                if (inv[i] != null) {
+                    this.inventoryContents[i] = inv[i].copy();
+                }
+            }
+
+            // 周囲のブロックを保存 (プレイヤー周辺半径 15x15x15)
+            this.blocks = new ArrayList<BlockData>();
+            WorldServer world = (WorldServer) player.worldObj;
+            int px = MathHelper.floor_double(player.posX);
+            int py = MathHelper.floor_double(player.posY);
+            int pz = MathHelper.floor_double(player.posZ);
+
+            for (int dx = -10; dx <= 10; dx++) {
+                for (int dy = -5; dy <= 10; dy++) {
+                    for (int dz = -10; dz <= 10; dz++) {
+                        int x = px + dx;
+                        int y = py + dy;
+                        int z = pz + dz;
+                        if (y >= 0 && y < 256) {
+                            int id = world.getBlockId(x, y, z);
+                            int meta = world.getBlockMetadata(x, y, z);
+                            this.blocks.add(new BlockData(x, y, z, id, meta));
+                        }
+                    }
+                }
+            }
+        }
+    }
+
+    // プレイヤー名 -> スナップショットキュー
+    private static final Map<String, LinkedList<Snapshot>> playerSnapshots = new HashMap<String, LinkedList<Snapshot>>();
+    
+    // イベント4の状態管理用変数
+    public static boolean isEvent4Active = false;
+    public static long event4StartTime = 0L;
+    public static EntityPlayerMP targetPlayer = null;
+    public static Snapshot rollbackTarget = null;
+    private static int soundTimer = 0;
+
+    public static void tickServer() {
+        MinecraftServer server = MinecraftServer.getServer();
+        if (server == null) return;
+
+        List players = server.getConfigurationManager().playerEntityList;
+        if (players == null) return;
+
+        long now = System.currentTimeMillis();
+
+        // 1. スナップショットの定期的記録 (5秒に1回, イベント中でない場合)
+        if (!isEvent4Active && server.getTickCounter() % 100 == 0) {
+            for (int i = 0; i < players.size(); i++) {
+                EntityPlayerMP player = (EntityPlayerMP) players.get(i);
+                String name = player.username;
+                
+                LinkedList<Snapshot> list = playerSnapshots.get(name);
+                if (list == null) {
+                    list = new LinkedList<Snapshot>();
+                    playerSnapshots.put(name, list);
+                }
+
+                list.addLast(new Snapshot(player));
+
+                // 60秒以上古いスナップショットを削除（履歴は最大12個＝60秒分）
+                while (list.size() > 12) {
+                    list.removeFirst();
+                }
+            }
+        }
+
+        // 2. イベント4のタイムライン処理
+        if (isEvent4Active && targetPlayer != null && rollbackTarget != null) {
+            long elapsed = now - event4StartTime;
+            WorldServer world = (WorldServer) targetPlayer.worldObj;
+
+            if (elapsed < 4000L) {
+                // === フェーズ1: 予兆 (時間の超高速逆行 ＆ 時計サウンド) ===
+                if (elapsed < 50L) {
+                    sendPlayWav(targetPlayer, "/sounds/clock.wav");
+                }
+                long newTime = world.getWorldTime() - 150L;
+                if (newTime < 0L) {
