+                    dipEnd = j - 1;
+                    break;
+                }
+            }
+        }
+        
+        if (dipStart == -1) return false;
+        
+        // 3. Analyze Word 1 (before dipStart) -> "That" / "Zatto" / "Datto"
+        int w1Start = -1;
+        for (int i = 2; i < dipStart; i++) {
+            if (volHistory[i] > threshold) {
+                w1Start = i;
+                break;
+            }
+        }
+        if (w1Start == -1) return false;
+        
+        int w1Len = dipStart - w1Start;
+        if (w1Len < 4 || w1Len > 14) return false; // Increased min length from 3 to 4 (~128ms)
+        
+        // 4. Analyze Word 2 (after dipEnd) -> "Thing" / "Singu" / "Shingu"
+        int w2End = -1;
+        for (int i = BUFFER_SIZE - 2; i > dipEnd; i--) {
+            if (volHistory[i] > threshold) {
+                w2End = i;
+                break;
+            }
+        }
+        if (w2End == -1) return false;
+        
+        int w2Len = w2End - dipEnd;
+        if (w2Len < 5 || w2Len > 16) return false; // Increased min length from 4 to 5 (~160ms)
